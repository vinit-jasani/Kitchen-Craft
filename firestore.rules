rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate IDs (Pillar 3)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for users collection
    match /users/{userId} {
      allow read, write: if isValidId(userId);
    }

    // Rules for customers collection
    match /customers/{customerId} {
      allow read, write: if isValidId(customerId);
    }

    // Rules for materials collection
    match /materials/{materialId} {
      allow read, write: if isValidId(materialId);
    }

    // Rules for estimates collection
    match /estimates/{estimateId} {
      allow read, write: if isValidId(estimateId);
    }
  }
}
